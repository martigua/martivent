      async function adminSave() {
        const cfg = ADMIN_TABLES[adminTable];
        const pk = cfg.pk || "id";
        const values = {};
        for (const el of document.querySelectorAll("#admin-form [data-fk]")) {
          const f = cfg.fields.find((x) => x.k === el.dataset.fk);
          if (f.type === "image") {
            const file = el.files[0];
            if (file) {
              if (file.size > 4 * 1024 * 1024) {
                showToast("Photo trop lourde (max 4 Mo).", "error");
                return;
              }
              const path =
                adminTable +
                "/" +
                Date.now() +
                "-" +
                file.name.replace(/[^a-zA-Z0-9.\-_]/g, "");
              const { error: upErr } = await sb.storage
                .from("assets")
                .upload(path, file, { contentType: file.type });
              if (upErr) {
                showToast("Erreur photo : " + upErr.message, "error");
                return;
              }
              values[f.k] =
                SUPABASE_URL + "/storage/v1/object/public/assets/" + path;
            } else values[f.k] = el.dataset.current || null;
          } else if (f.type === "checkbox") values[f.k] = el.checked;
          else if (f.type === "number")
            values[f.k] = el.value === "" ? null : Number(el.value);
          else values[f.k] = el.value === "" ? null : el.value;
        }
        if (adminTable === "notifications" && !adminEditingId) {
          values.auteur =
            ((currentProfile || {}).prenom || "") +
            " " +
            ((currentProfile || {}).nom || "");
        }
        let error;
        if (adminEditingId)
          ({ error } = await sb
            .from(adminTable)
            .update(values)
            .eq(pk, adminEditingId));
        else ({ error } = await sb.from(adminTable).insert(values));
        if (error) {
          showToast("Erreur : " + error.message, "error");
          return;
        }
        adminCancel();
        loadAdminList();
        refreshPublicContent();
        showToast("Enregistré ! Visible immédiatement sur le site ✅");
      }

