    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script>
      // ═══════════════════════════════════════════════════
      // CONFIGURATION SUPABASE — À REMPLIR (voir GUIDE-SUPABASE.md)
      // ═══════════════════════════════════════════════════
      const SUPABASE_URL = "https://ewdfsenozmswqzhrlhgu.supabase.co";
      const SUPABASE_ANON_KEY =
        "sb_publishable_c2XJ7aQPVia8XDwt4CqVcw_tnlbPHX2";

      const isConfigured = !SUPABASE_URL.includes("VOTRE-PROJET");
      const sb = isConfigured
        ? supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY)
        : null;

      let currentUser = null;
      let currentProfile = null;
      let editMode = false;

      // ── PAGE NAVIGATION ──
      function showPage(p) {
        document
          .querySelectorAll(".page")
          .forEach((el) => el.classList.remove("active"));
        document.getElementById("page-" + p).classList.add("active");
        if (p === "home") window.scrollTo(0, 0);
        document.getElementById("nav-public").style.display =
          p === "home" ? "flex" : "none";
        document.getElementById("nav-membre").style.display =
          p === "membre" ? "flex" : "none";
      }
      function scrollToSection(id) {
        showPage("home");
        setTimeout(() => {
          const el = document.getElementById(id);
          if (el) el.scrollIntoView({ behavior: "smooth" });
        }, 50);
      }
      function showMemberPanel(p) {
        document
          .querySelectorAll(".membre-panel")
          .forEach((el) => el.classList.remove("active"));
        document.getElementById("panel-" + p).classList.add("active");
        document
          .querySelectorAll(".sidebar-nav-item")
          .forEach((el) => el.classList.remove("active"));
        if (typeof event !== "undefined" && event && event.target) {
          const item = event.target.closest(".sidebar-nav-item");
          if (item) item.classList.add("active");
        }
        showPage("membre");
        if (p === "documents") loadDocuments();
        if (p === "enfants") loadChildren();
        if (p === "admin") {
          renderAdminTabs();
          switchAdminTable(adminTable);
        }
        if (p === "membres") loadMembres();
        if (p === "messages") loadMessages();
        if (p === "notifications") loadNotifications();
        if (p === "mon-equipe") loadMonEquipe();
        if (p === "presences") loadPresences();
        if (p === "dispos") loadDispos();
        if (p === "selection") loadSelectionPanel();
      }

      // ── AUTH ──
      async function doLogin() {
        const email = document.getElementById("login-email").value.trim();
        const pwd = document.getElementById("login-pwd").value;
        if (!isConfigured) {
          demoLogin();
          return;
        }
        if (!email || !pwd) {
          showToast("Renseignez email et mot de passe.", "error");
          return;
        }
        const { data, error } = await sb.auth.signInWithPassword({
          email,
          password: pwd,
        });
        if (error) {
          showToast("Connexion impossible : " + error.message, "error");
          return;
        }
        currentUser = data.user;
        await loadProfile();
        closeModal("login");
        showPage("membre");
        showToast(
          "Bienvenue, " + (currentProfile?.prenom || "membre") + " ! 👋",
        );
      }

      async function doRegister() {
        const prenom = document.getElementById("reg-prenom").value.trim();
        const nom = document.getElementById("reg-nom").value.trim();
        const email = document.getElementById("reg-email").value.trim();
        const pwd = document.getElementById("reg-pwd").value;
        const type = document.getElementById("reg-type").value;
        const equipe = document.getElementById("reg-equipe").value;
        const licence = document.getElementById("reg-licence").value.trim();
        if (!isConfigured) {
          demoLogin(prenom, nom, equipe, type);
          return;
        }
        if (!prenom || !nom || !email || pwd.length < 6 || !licence) {
          showToast(
            "Remplissez tous les champs, y compris le numéro de licence (mot de passe : 6 caractères min).",
            "error",
          );
          return;
        }
        const { data: licOk, error: licErr } = await sb.rpc(
          "verifier_licence",
          { num: licence },
        );
        if (licErr || !licOk) {
          showToast(
            "Numéro de licence inconnu ou déjà utilisé. Contactez le club pour obtenir votre numéro.",
            "error",
          );
          return;
        }
        const { data, error } = await sb.auth.signUp({
          email,
          password: pwd,
          options: {
            data: { prenom, nom, equipe, type_compte: type, licence },
          },
        });
        if (error) {
          showToast("Inscription impossible : " + error.message, "error");
          return;
        }
        if (!data.session) {
          closeModal("login");
          showToast(
            "Compte créé ! Vérifiez votre boîte mail pour confirmer votre adresse. 📧",
          );
          return;
        }
        currentUser = data.user;
        await loadProfile();
        closeModal("login");
        showPage("membre");
        if (type !== "joueur") {
          showMemberPanel("enfants");
          showToast("Compte créé ! Ajoutez vos enfants. 👶");
        } else showToast("Compte créé ! Bienvenue au Martigua ! 🤾");
      }

      async function logout() {
        if (sb) await sb.auth.signOut();
        currentUser = null;
        currentProfile = null;
        document.getElementById("btn-login").style.display = "block";
        document.getElementById("btn-avatar").style.display = "none";
        document.getElementById("btn-logout").style.display = "none";
        showPage("home");
        showToast("Vous êtes déconnecté·e.");
      }

      // Mode démo si Supabase non configuré
      function demoLogin(prenom, nom, equipe, type) {
        currentProfile = {
          prenom: prenom || "Jean",
          nom: nom || "Dupont",
          equipe: equipe || "Seniors A",
          email: "demo@martigua.fr",
          telephone: "06 12 34 56 78",
          adresse: "12 Rue de la Paix, 75019 Paris",
          poste: "Pivot",
          numero: "7",
          date_naissance: "1995-03-15",
          urgence_nom: "Marie Dupont",
          urgence_tel: "06 98 76 54 32",
          urgence_relation: "Conjoint(e)",
          type_compte: type || "joueur",
        };
        closeModal("login");
        renderProfile();
        showPage("membre");
        showToast(
          "Mode démo (Supabase non configuré) — voir GUIDE-SUPABASE.md",
        );
      }

      // ── PROFIL ──
      async function loadProfile() {
        if (!sb || !currentUser) return;
        const { data, error } = await sb
          .from("profiles")
          .select("*")
          .eq("id", currentUser.id)
          .single();
        if (error) {
          showToast("Erreur chargement profil", "error");
          return;
        }
        currentProfile = data;
        renderProfile();
        checkAnnonceBanner();
        refreshMessagesBadge();
      }

      function renderProfile() {
        const p = currentProfile;
        if (!p) return;
        const initials = (
          (p.prenom || "?")[0] + (p.nom || "?")[0]
        ).toUpperCase();
        const fullname = (p.prenom || "") + " " + (p.nom || "");
        document.getElementById("btn-login").style.display = "none";
        document.getElementById("btn-avatar").style.display = "flex";
        document.getElementById("btn-logout").style.display = "block";
        const avHTML = p.photo_url
          ? `<img src="${esc(p.photo_url)}" alt="">`
          : initials;
        document.getElementById("btn-avatar").innerHTML = avHTML;
        document.getElementById("sidebar-avatar").innerHTML = avHTML;
        document.getElementById("sidebar-name").textContent = fullname;
        document.getElementById("sidebar-equipe").textContent = p.equipe || "—";
        document.getElementById("sidebar-role").textContent =
          p.type_compte === "parent"
            ? "Parent"
            : p.type_compte === "les-deux"
              ? "Joueur·se & Parent"
              : "Joueur·se";
        document
          .querySelectorAll(".admin-only")
          .forEach((el) => (el.style.display = p.is_admin ? "" : "none"));
        document
          .querySelectorAll(".coach-only")
          .forEach(
            (el) => (el.style.display = p.is_coach || p.is_admin ? "" : "none"),
          );
        if (p.is_admin)
          document.getElementById("sidebar-role").textContent += " · Admin 🛠️";
        if (p.is_coach && !p.is_admin)
          document.getElementById("sidebar-role").textContent += " · Coach 🎯";
        document.getElementById("fiche-av").innerHTML = avHTML;
        document.getElementById("fiche-fullname").textContent = fullname;
        document.getElementById("fiche-pos-badge").textContent = p.poste || "—";
        document.querySelector(".fiche-number").textContent =
          "#" + (p.numero || "–");
        // Champs
        document.querySelectorAll(".view-field[data-key]").forEach((el) => {
          const k = el.dataset.key;
          let v = p[k] || "—";
          if (k === "numero" && p[k]) v = "#" + p[k];
          if (k === "date_naissance" && p[k])
            v = new Date(p[k]).toLocaleDateString("fr-FR");
          el.textContent = v;
        });
        document.querySelectorAll(".edit-field[data-key]").forEach((el) => {
          el.value = p[el.dataset.key] || "";
        });
      }

      function toggleEdit() {
        editMode = !editMode;
        document
          .querySelectorAll(".view-field")
          .forEach((el) => (el.style.display = editMode ? "none" : ""));
        document
          .querySelectorAll(".edit-field")
          .forEach((el) => (el.style.display = editMode ? "" : "none"));
        document.getElementById("editBtn").style.display = editMode
          ? "none"
          : "";
        document.getElementById("saveBtn").style.display = editMode
          ? ""
          : "none";
      }

      async function saveProfile() {
        const updates = {};
        document.querySelectorAll(".edit-field[data-key]").forEach((el) => {
          if (!el.disabled) updates[el.dataset.key] = el.value || null;
        });
        if (sb && currentUser) {
          const { error } = await sb
            .from("profiles")
            .update(updates)
            .eq("id", currentUser.id);
          if (error) {
            showToast("Erreur : " + error.message, "error");
            return;
          }
          Object.assign(currentProfile, updates);
        } else if (currentProfile) {
          Object.assign(currentProfile, updates);
        }
        renderProfile();
        toggleEdit();
        showToast("Profil mis à jour ! ✅");
      }

      // ── ENFANTS ──
      async function loadChildren() {
        const list = document.getElementById("children-list");
        list.querySelectorAll(".child-card").forEach((el) => el.remove());
        if (!sb || !currentUser) return;
        const { data, error } = await sb
          .from("children")
          .select("*")
          .eq("parent_id", currentUser.id)
          .order("created_at");
        if (error || !data) return;
        data.forEach((c) => list.insertBefore(childCard(c), list.firstChild));
      }

      function childCard(c) {
        const div = document.createElement("div");
        div.className = "child-card";
        const initials = (
          (c.prenom || "?")[0] + (c.nom || "?")[0]
        ).toUpperCase();
        const dob = c.date_naissance
          ? new Date(c.date_naissance).toLocaleDateString("fr-FR")
          : "—";
        const avatar = c.photo_url
          ? `<img src="${esc(c.photo_url)}" alt="">`
          : initials;
        div.innerHTML = `
    <div class="child-header">
      <div class="child-avatar">${avatar}</div>
      <div><h3>${c.prenom} ${c.nom}</h3><div class="child-meta">${c.categorie || ""} – Né·e le ${dob}</div></div>
    </div>
    <div class="child-info-row"><span>Catégorie</span><span>${c.categorie || "—"}</span></div>
    <div class="child-info-row"><span>Poste</span><span>${c.poste || "Non défini"}</span></div>
    <div class="child-info-row"><span>Infos médicales</span><span>${c.infos_medicales || "Aucune"}</span></div>
    <div style="margin-top:16px">
      <button class="doc-btn danger" style="width:100%" onclick="deleteChild('${c.id}')">🗑️ Supprimer le profil</button>
    </div>`;
        return div;
      }

      async function addChild() {
        const prenom = document.getElementById("child-prenom").value.trim();
        const nom = document.getElementById("child-nom").value.trim();
        const dob = document.getElementById("child-dob").value || null;
        const categorie = document.getElementById("child-cat").value;
        const poste = document.getElementById("child-poste").value || null;
        const medical =
          (
            document.getElementById("child-medical") || { value: "" }
          ).value.trim() || null;
        if (!prenom || !nom) {
          showToast("Prénom et nom requis.", "error");
          return;
        }
        if (sb && currentUser) {
          let photo_url = null;
          const photoInput = document.getElementById("child-photo");
          const pf = photoInput && photoInput.files[0];
          if (pf) {
            if (pf.size > 3 * 1024 * 1024) {
              showToast("Photo trop lourde (max 3 Mo).", "error");
              return;
            }
            const ppath =
              "avatars/enfant-" +
              currentUser.id +
              "-" +
              Date.now() +
              "." +
              (pf.name.split(".").pop() || "png");
            const { error: pErr } = await sb.storage
              .from("assets")
              .upload(ppath, pf, { contentType: pf.type });
            if (pErr) {
              showToast("Erreur photo : " + pErr.message, "error");
              return;
            }
            photo_url =
              SUPABASE_URL + "/storage/v1/object/public/assets/" + ppath;
          }
          const { error } = await sb
            .from("children")
            .insert({
              parent_id: currentUser.id,
              prenom,
              nom,
              date_naissance: dob,
              categorie,
              poste,
              infos_medicales: medical,
              photo_url,
            });
          if (error) {
            showToast("Erreur : " + error.message, "error");
            return;
          }
          if (photoInput) photoInput.value = "";
          await loadChildren();
        } else {
          const list = document.getElementById("children-list");
          list.insertBefore(
            childCard({
              id: "demo",
              prenom,
              nom,
              date_naissance: dob,
              categorie,
              poste,
            }),
            list.firstChild,
          );
        }
        closeModal("addChild");
        showToast(`Profil de ${prenom} ${nom} créé ! 👶`);
      }

      async function deleteChild(id) {
        if (!confirm("Supprimer ce profil enfant ?")) return;
        if (sb && currentUser && id !== "demo") {
          const { error } = await sb.from("children").delete().eq("id", id);
          if (error) {
            showToast("Erreur : " + error.message, "error");
            return;
          }
        }
        loadChildren();
        showToast("Profil supprimé.");
      }

      // ── DOCUMENTS (Supabase Storage, dossiers dynamiques) ──
      let currentDocsFolder = "";
      let docsFoldersCache = [];

      let dossiersMetaCache = {};
      async function loadDossiersMeta() {
        if (!sb) return;
        const { data } = await sb.from("dossiers_meta").select("*");
        dossiersMetaCache = {};
        (data || []).forEach((d) => (dossiersMetaCache[d.nom] = d));
      }

      async function renderDocFolders() {
        const grid = document.getElementById("docs-folders");
        const isAdm = currentProfile && currentProfile.is_admin;
        if (currentDocsFolder) {
          grid.innerHTML = `<div class="folder-card" onclick="openDocsFolder('')"><span class="folder-icon">⬅️</span><div><h4>Retour</h4><p>Tous les dossiers</p></div></div>`;
        } else {
          if (sb && currentUser) {
            const { data } = await sb.storage
              .from("documents")
              .list("", { limit: 200 });
            docsFoldersCache = (data || [])
              .filter((f) => f.id === null)
              .map((f) => f.name);
            await loadDossiersMeta();
          }
          // Filtre les dossiers privés pour les non-admins
          const visibles = docsFoldersCache.filter((name) => {
            const meta = dossiersMetaCache[name];
            return isAdm || !meta || !meta.prive;
          });
          grid.innerHTML =
            visibles
              .map((name) => {
                const enc = encodeURIComponent(name);
                const meta = dossiersMetaCache[name];
                const lock = meta && meta.prive ? "🔒 " : "👥 ";
                const tag =
                  meta && meta.prive ? "Privé (admins)" : "Public (tous)";
                const togglePriv = isAdm
                  ? `<button class="doc-btn" style="flex-shrink:0" onclick="event.stopPropagation();toggleDocFolderPrivacy(decodeURIComponent('${enc}'), ${meta && meta.prive ? "true" : "false"})" title="${meta && meta.prive ? "Rendre public" : "Rendre privé"}">${meta && meta.prive ? "🔒" : "👥"}</button>`
                  : "";
                return `<div class="folder-card"><span class="folder-icon" onclick="openDocsFolder(decodeURIComponent('${enc}'))">📁</span>
        <div style="flex:1;cursor:pointer" onclick="openDocsFolder(decodeURIComponent('${enc}'))"><h4>${lock}${esc(name)}</h4><p>${tag}</p></div>
        ${togglePriv}
        ${isAdm ? `<button class="doc-btn" style="flex-shrink:0" onclick="event.stopPropagation();renameDocsFolder(decodeURIComponent('${enc}'))" title="Renommer">✏️</button>` : ""}</div>`;
              })
              .join("") ||
            '<p style="color:#888">Aucun dossier disponible. Les admins peuvent en créer avec le bouton 📁 Nouveau dossier.</p>';
        }
        document.getElementById("docs-title").textContent = currentDocsFolder
          ? "📄 Dossier : " + currentDocsFolder
          : "📄 Documents";
      }

      async function newDocsFolder() {
        const name = prompt("Nom du nouveau dossier :");
        if (!name) return;
        const clean = name.trim().replace(/['"\\\/]/g, "-");
        const isPrivate = confirm(
          "Ce dossier doit-il être RÉSERVÉ aux administrateur·rices ?\n\n• OK = 🔒 Privé (admins uniquement)\n• Annuler = 👥 Public (tous les adhérent·es)",
        );
        const { error } = await sb.storage
          .from("documents")
          .upload(clean + "/.keep", new Blob([" "]), { upsert: true });
        if (error) {
          showToast(
            "Création impossible (" +
              error.message +
              "). Vérifiez que supabase-correctifs.sql a été exécuté.",
            "error",
          );
          return;
        }
        // Enregistre la visibilité dans la table dossiers_meta
        await sb.from("dossiers_meta").upsert({ nom: clean, prive: isPrivate });
        renderDocFolders();
        showToast(
          "Dossier « " +
            clean +
            " » créé en mode " +
            (isPrivate ? "🔒 privé" : "👥 public"),
        );
      }

      async function toggleDocFolderPrivacy(name, currentlyPrivate) {
        const newVal = !currentlyPrivate;
        const { error } = await sb
          .from("dossiers_meta")
          .upsert({ nom: name, prive: newVal });
        if (error) {
          showToast("Erreur : " + error.message, "error");
          return;
        }
        renderDocFolders();
        showToast(
          "Dossier « " + name + " » → " + (newVal ? "🔒 privé" : "👥 public"),
        );
      }

      async function renameDocsFolder(oldName) {
        const newName = prompt("Nouveau nom du dossier :", oldName);
        if (!newName || newName === oldName) return;
        const clean = newName.trim().replace(/['"\\\/]/g, "-");
        const { data, error } = await sb.storage
          .from("documents")
          .list(oldName, { limit: 200 });
        if (error) {
          showToast("Erreur : " + error.message, "error");
          return;
        }
        for (const f of data || []) {
          const { error: mvErr } = await sb.storage
            .from("documents")
            .move(oldName + "/" + f.name, clean + "/" + f.name);
          if (mvErr) {
            showToast("Erreur : " + mvErr.message, "error");
            return;
          }
        }
        if (currentDocsFolder === oldName) currentDocsFolder = clean;
        renderDocFolders();
        loadDocuments();
        showToast("Dossier renommé en « " + clean + " » ✅");
      }

      function openDocsFolder(k) {
        currentDocsFolder = k;
        renderDocFolders();
        loadDocuments();
      }

      async function loadDocuments() {
        renderDocFolders();
        if (!sb || !currentUser) return;
        const { data, error } = await sb.storage
          .from("documents")
          .list(currentDocsFolder, { limit: 100, sortBy: { column: "name" } });
        const list = document.getElementById("docs-list");
        if (error) {
          list.innerHTML = '<p style="color:#888">Erreur de chargement.</p>';
          return;
        }
        const files = (data || []).filter(
          (f) => f.metadata && f.name && !f.name.startsWith("."),
        );
        if (files.length === 0) {
          list.innerHTML =
            '<p style="color:#888">Aucun document dans ' +
            (currentDocsFolder ? "ce dossier" : "la racine") +
            " pour le moment.</p>";
          return;
        }
        list.innerHTML = files
          .map((f) => {
            const ext = f.name.split(".").pop().toLowerCase();
            const badge =
              ext === "pdf"
                ? "pdf"
                : ["doc", "docx"].includes(ext)
                  ? "word"
                  : ["xls", "xlsx", "csv"].includes(ext)
                    ? "excel"
                    : "img";
            const size = f.metadata?.size
              ? Math.round(f.metadata.size / 1024) + " Ko"
              : "";
            const fullPath =
              (currentDocsFolder ? currentDocsFolder + "/" : "") + f.name;
            const enc = encodeURIComponent(fullPath);
            const isAdm = currentProfile && currentProfile.is_admin;
            return `<div class="doc-row" data-name="${esc(f.name.toLowerCase())}"><span class="doc-type-badge ${badge}">${ext.toUpperCase()}</span>
      <div class="doc-info"><h4>${esc(f.name)}</h4><p>${currentDocsFolder || "Racine"}</p></div>
      <span class="doc-size">${size}</span>
      <div class="doc-actions"><button class="doc-btn" onclick="downloadDoc(decodeURIComponent('${enc}'))">📖 Ouvrir</button>${isAdm ? `<button class="doc-btn danger" onclick="deleteDocument(decodeURIComponent('${enc}'))">🗑️</button>` : ""}</div></div>`;
          })
          .join("");
      }

      async function uploadDocument(input) {
        const f = input.files[0];
        if (!f) return;
        if (f.size > 10 * 1024 * 1024) {
          showToast("Fichier trop lourd (max 10 Mo).", "error");
          input.value = "";
          return;
        }
        const name = f.name.replace(/['"\\\/]/g, "-");
        const path = (currentDocsFolder ? currentDocsFolder + "/" : "") + name;
        const { error } = await sb.storage
          .from("documents")
          .upload(path, f, { upsert: true, contentType: f.type });
        input.value = "";
        if (error) {
          showToast(
            "Ajout impossible (" +
              error.message +
              "). Vérifiez que le script supabase-correctifs.sql a été exécuté.",
            "error",
          );
          return;
        }
        loadDocuments();
        showToast(
          "Document ajouté dans " +
            (currentDocsFolder || "la racine") +
            " ! 📄",
        );
      }

      async function deleteDocument(name) {
        if (!confirm("Supprimer ce document ?")) return;
        const { error } = await sb.storage.from("documents").remove([name]);
