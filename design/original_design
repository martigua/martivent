      async function adminImportSave() {
        const lines = document
          .getElementById("admin-import-text")
          .value.split("\n")
          .map((l) => l.trim())
          .filter(Boolean);
        if (lines.length === 0) {
          showToast("Aucune ligne à importer.", "error");
          return;
        }
        const rows = [];
        const errors = [];
        lines.forEach((line, i) => {
          const parts = line.split(";").map((p) => p.trim());
          if (parts.length < 2) {
            errors.push("Ligne " + (i + 1) + " : format invalide");
            return;
          }
          let dateISO = null;
          const m = parts[0].match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
          if (m)
            dateISO =
              m[3] + "-" + m[2].padStart(2, "0") + "-" + m[1].padStart(2, "0");
          else if (/^\d{4}-\d{2}-\d{2}$/.test(parts[0])) dateISO = parts[0];
          if (!dateISO) {
            errors.push(
              "Ligne " + (i + 1) + " : date invalide (attendu JJ/MM/AAAA)",
            );
            return;
          }
          rows.push({
            date_match: dateISO,
            titre: parts[1],
            lieu: parts[2] || null,
            type: parts[3] || "Champ.",
          });
        });
        if (errors.length) {
          showToast(
            errors[0] +
              (errors.length > 1
                ? " (+" + (errors.length - 1) + " autres)"
                : ""),
            "error",
          );
          return;
        }
        const { error } = await sb.from("matchs").insert(rows);
        if (error) {
          showToast("Erreur : " + error.message, "error");
          return;
        }
        document.getElementById("admin-import-text").value = "";
        document.getElementById("admin-import-wrap").style.display = "none";
        loadAdminList();
        refreshPublicContent();
        showToast(rows.length + " match(s) importé(s) ! ✅");
      }

