<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Martigua Handball – Paris 19e</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700;900&display=swap"
      rel="stylesheet"
    />
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      :root {
        --yellow: #f5c800;
        --yellow-dark: #d4a900;
        --black: #0d0d0d;
        --dark: #1a1a1a;
        --mid: #2e2e2e;
        --white: #ffffff;
        --gray: #888;
        --green: #22c55e;
        --red: #ef4444;
        --blue: #3b82f6;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        font-family: "Inter", sans-serif;
        background: var(--black);
        color: var(--white);
        overflow-x: hidden;
      }

      /* ── NAV ── */
      nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 200;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 40px;
        height: 72px;
        background: rgba(13, 13, 13, 0.95);
        backdrop-filter: blur(12px);
        border-bottom: 2px solid var(--yellow);
      }
      .nav-logo {
        display: flex;
        align-items: center;
        gap: 14px;
        text-decoration: none;
        cursor: pointer;
      }
      .nav-logo img {
        height: 52px;
        width: auto;
        border-radius: 6px;
        border: 1px solid var(--yellow);
      }
      .nav-logo span {
        font-family: "Bebas Neue", sans-serif;
        font-size: 1.4rem;
        color: var(--yellow);
        letter-spacing: 2px;
        line-height: 1.1;
      }
      .nav-links {
        display: flex;
        gap: 28px;
        list-style: none;
      }
      .nav-links a {
        color: var(--white);
        text-decoration: none;
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        transition: color 0.2s;
        cursor: pointer;
      }
      .nav-links a:hover {
        color: var(--yellow);
      }
      .nav-right {
        display: flex;
        gap: 12px;
        align-items: center;
      }
      .nav-cta {
        background: var(--yellow);
        color: var(--black);
        padding: 10px 20px;
        border-radius: 4px;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        text-decoration: none;
        cursor: pointer;
        border: none;
        transition: background 0.2s;
      }
      .nav-cta:hover {
        background: var(--yellow-dark);
      }
      .nav-login {
        background: transparent;
        color: var(--yellow);
        border: 2px solid var(--yellow);
        padding: 8px 18px;
        border-radius: 4px;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.2s;
      }
      .nav-login:hover {
        background: var(--yellow);
        color: var(--black);
      }
      .nav-avatar {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: var(--yellow);
        color: var(--black);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 0.85rem;
        cursor: pointer;
        border: none;
      }

      /* ── PAGE SYSTEM ── */
      .page {
        display: none;
      }
      .page.active {
        display: block;
      }

      /* ── HERO ── */
      #hero {
        min-height: 100vh;
        display: flex;
        align-items: center;
        padding: 100px 40px 60px;
        position: relative;
        overflow: hidden;
      }
      .hero-bg {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, #0d0d0d 55%, #1a1500 100%);
      }
      .hero-stripe {
        position: absolute;
        right: 0;
        top: 0;
        bottom: 0;
        width: 38%;
        background: var(--yellow);
        clip-path: polygon(18% 0, 100% 0, 100% 100%, 0% 100%);
        z-index: 0;
      }
      .hero-content {
        position: relative;
        z-index: 2;
        max-width: 700px;
      }
      .hero-eyebrow {
        display: inline-block;
        background: var(--yellow);
        color: var(--black);
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 3px;
        text-transform: uppercase;
        padding: 6px 14px;
        border-radius: 2px;
        margin-bottom: 28px;
      }
      .hero-title {
        font-family: "Bebas Neue", sans-serif;
        font-size: clamp(4rem, 9vw, 8rem);
        line-height: 0.9;
        color: var(--white);
        margin-bottom: 10px;
      }
      .hero-title .yellow {
        color: var(--yellow);
      }
      .hero-subtitle {
        font-size: 1rem;
        color: #aaa;
        font-weight: 500;
        letter-spacing: 3px;
        text-transform: uppercase;
        margin-bottom: 32px;
      }
      .hero-desc {
        font-size: 1.05rem;
        color: #ccc;
        line-height: 1.7;
        max-width: 480px;
        margin-bottom: 44px;
      }
      .hero-btns {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
      }
      .btn-primary {
        background: var(--yellow);
        color: var(--black);
        padding: 16px 36px;
        border-radius: 4px;
        font-weight: 800;
        font-size: 0.9rem;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        text-decoration: none;
        transition:
          background 0.2s,
          transform 0.15s;
        display: inline-block;
        cursor: pointer;
        border: none;
      }
      .btn-primary:hover {
        background: var(--yellow-dark);
        transform: translateY(-2px);
      }
      .btn-secondary {
        border: 2px solid var(--white);
        color: var(--white);
        padding: 14px 34px;
        border-radius: 4px;
        font-weight: 700;
        font-size: 0.9rem;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        text-decoration: none;
        transition: all 0.2s;
        display: inline-block;
        cursor: pointer;
        background: transparent;
      }
      .btn-secondary:hover {
        border-color: var(--yellow);
        color: var(--yellow);
        transform: translateY(-2px);
      }
      .hero-logo-float {
        position: absolute;
        right: 5%;
        top: 50%;
        transform: translateY(-50%);
        z-index: 3;
        animation: float 4s ease-in-out infinite;
      }
      .hero-logo-float img {
        width: 280px;
        height: auto;
        border-radius: 12px;
        box-shadow: 0 0 60px rgba(245, 200, 0, 0.35);
      }
      @keyframes float {
        0%,
        100% {
          transform: translateY(-50%) translateY(0);
        }
        50% {
          transform: translateY(-50%) translateY(-14px);
        }
      }

      .stats-band {
        background: var(--yellow);
        padding: 28px 40px;
        display: flex;
        justify-content: center;
        gap: 80px;
        flex-wrap: wrap;
      }
      .stat-item {
        text-align: center;
      }
      .stat-num {
        font-family: "Bebas Neue", sans-serif;
        font-size: 2.8rem;
        color: var(--black);
        line-height: 1;
      }
      .stat-label {
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: rgba(0, 0, 0, 0.6);
        margin-top: 4px;
      }

      section {
        padding: 100px 40px;
      }
      .section-eyebrow {
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--yellow);
        margin-bottom: 16px;
      }
      .section-title {
        font-family: "Bebas Neue", sans-serif;
        font-size: clamp(2.4rem, 5vw, 4rem);
        line-height: 1.05;
        margin-bottom: 20px;
      }
      .section-lead {
        font-size: 1.05rem;
        color: #aaa;
        line-height: 1.75;
        max-width: 560px;
      }

      /* ── ACTUALITÉS ── */
      #actualites {
        background: var(--dark);
      }
      .actu-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 56px;
        flex-wrap: wrap;
        gap: 20px;
      }
      .actu-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 24px;
      }
      .actu-card {
        background: var(--mid);
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid #333;
        transition:
          border-color 0.2s,
          transform 0.2s;
      }
      .actu-card:hover {
        border-color: var(--yellow);
        transform: translateY(-4px);
      }
      .actu-card-img {
        width: 100%;
        height: 180px;
        background: var(--black);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 4rem;
        border-bottom: 3px solid var(--yellow);
      }
      .actu-card-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }
      .actu-card-body {
        padding: 24px;
      }
      .actu-tag {
        font-size: 0.68rem;
        font-weight: 800;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--yellow);
        margin-bottom: 10px;
        display: block;
      }
      .actu-card h3 {
        font-size: 1.05rem;
        font-weight: 700;
        margin-bottom: 10px;
        line-height: 1.4;
      }
      .actu-card p {
        font-size: 0.88rem;
        color: #888;
        line-height: 1.6;
      }
      .actu-date {
        font-size: 0.75rem;
        color: #666;
        margin-top: 16px;
        display: block;
      }

      /* ── ÉQUIPES ── */
      #equipes {
        background: var(--black);
      }
      .equipes-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 20px;
        margin-top: 56px;
      }
      .equipe-card {
        border: 2px solid #333;
        border-radius: 8px;
        padding: 36px 28px;
        text-align: center;
        transition:
          border-color 0.2s,
          background 0.2s;
        cursor: pointer;
      }
      .equipe-card:hover {
        border-color: var(--yellow);
        background: rgba(245, 200, 0, 0.04);
      }
      .equipe-icon {
        font-size: 3rem;
        margin-bottom: 18px;
      }
      .equipe-photo {
        width: 100%;
        height: 140px;
        object-fit: cover;
        border-radius: 8px;
        margin-bottom: 16px;
        display: block;
      }
      .bureau-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 50%;
      }
      .fiche-avatar img,
      .membre-avatar-lg img,
      .nav-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 50%;
      }
      .pres-on-green {
        border-color: var(--green) !important;
        color: var(--green) !important;
      }
      .pres-on-red {
        border-color: var(--red) !important;
        color: var(--red) !important;
      }

      /* ── DISPONIBILITÉS ── */
      .dispo-match-card {
        background: var(--dark);
        border: 1px solid #333;
        border-radius: 12px;
        padding: 22px 24px;
        margin-bottom: 16px;
        transition: border-color 0.2s;
      }
      .dispo-match-card:hover {
        border-color: #555;
      }
      .dispo-match-card.selected-card {
        border-color: #f97316;
        box-shadow: 0 0 0 1px rgba(249, 115, 22, 0.2);
      }
      .dispo-date-box {
        background: var(--yellow);
        color: var(--black);
        border-radius: 8px;
        padding: 10px 14px;
        text-align: center;
        min-width: 60px;
        flex-shrink: 0;
      }
      .dispo-date-box .day {
        font-family: "Bebas Neue", sans-serif;
        font-size: 1.8rem;
        line-height: 1;
      }
      .dispo-date-box .month {
        font-size: 0.62rem;
        font-weight: 800;
        letter-spacing: 1px;
        text-transform: uppercase;
      }
      .dispo-btn {
        padding: 10px 22px;
        border-radius: 8px;
        border: 2px solid #444;
        background: transparent;
        color: #888;
        font-size: 0.82rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.2s;
        font-family: "Inter", sans-serif;
      }
      .dispo-btn:hover {
        border-color: #888;
        color: var(--white);
      }
      .dispo-btn.active-dispo {
        border-color: var(--green);
        background: rgba(34, 197, 94, 0.12);
        color: var(--green);
      }
      .dispo-btn.active-non-dispo {
        border-color: var(--red);
        background: rgba(239, 68, 68, 0.12);
        color: var(--red);
      }
      .dispo-compteur {
        display: flex;
        gap: 12px;
        margin-top: 14px;
        flex-wrap: wrap;
      }
      .dispo-count-badge {
        font-size: 0.72rem;
        font-weight: 700;
        padding: 3px 10px;
        border-radius: 20px;
      }
      .dispo-count-badge.green {
        background: rgba(34, 197, 94, 0.12);
        color: var(--green);
      }
      .dispo-count-badge.red {
        background: rgba(239, 68, 68, 0.12);
        color: var(--red);
      }

      /* ── SÉLECTION COACH ── */
      .selection-group {
        margin-bottom: 8px;
      }
      .selection-group-header {
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 2px;
        text-transform: uppercase;
        padding: 10px 14px;
        border-radius: 8px;
        margin-bottom: 4px;
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .selection-group-header.green {
        background: rgba(34, 197, 94, 0.1);
        color: var(--green);
      }
      .selection-group-header.orange {
        background: rgba(245, 200, 0, 0.1);
        color: var(--yellow);
      }
      .selection-group-header.red {
        background: rgba(239, 68, 68, 0.1);
        color: var(--red);
      }
      .fire-btn {
        background: none;
        border: 1px solid #444;
        border-radius: 6px;
        padding: 6px 12px;
        cursor: pointer;
        font-size: 0.9rem;
        line-height: 1;
        transition: all 0.2s;
        flex-shrink: 0;
      }
      .fire-btn:hover {
        border-color: #f97316;
        background: rgba(249, 115, 22, 0.1);
      }
      .fire-btn.active {
        border-color: #f97316;
        background: rgba(249, 115, 22, 0.15);
      }
      .selection-match-select {
        width: 100%;
        background: var(--mid);
        border: 1px solid #444;
        border-radius: 10px;
        padding: 13px 16px;
        color: var(--white);
        font-family: "Inter", sans-serif;
        font-size: 0.95rem;
        outline: none;
        cursor: pointer;
        margin-bottom: 24px;
        transition: border-color 0.2s;
      }
      .selection-match-select:focus {
        border-color: var(--yellow);
      }
      .membre-row-av {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: var(--yellow);
        color: var(--black);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 0.7rem;
        flex-shrink: 0;
        overflow: hidden;
      }
      .membre-row-av img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      .equipe-card h3 {
        font-family: "Bebas Neue", sans-serif;
        font-size: 1.5rem;
        letter-spacing: 1px;
        margin-bottom: 8px;
      }
      .equipe-card p {
        font-size: 0.85rem;
        color: #888;
        line-height: 1.5;
      }
      .equipe-badge {
        display: inline-block;
        margin-top: 14px;
        background: var(--yellow);
        color: var(--black);
        font-size: 0.68rem;
        font-weight: 800;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        padding: 4px 12px;
        border-radius: 20px;
      }
      .equipe-ffhb {
        display: block;
        margin-top: 14px;
        color: var(--yellow);
        text-decoration: none;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.5px;
        border: 1px solid rgba(245, 200, 0, 0.4);
        border-radius: 6px;
        padding: 8px 12px;
        transition: all 0.2s;
      }
      .equipe-ffhb:hover {
        background: var(--yellow);
        color: var(--black);
      }

      /* ── AGENDA ── */
      #agenda {
        background: var(--dark);
      }
      .agenda-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        margin-top: 56px;
        align-items: start;
      }
      .match-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
      }
      .match-card {
        background: var(--mid);
        border-radius: 8px;
        padding: 20px 24px;
        display: flex;
        align-items: center;
        gap: 20px;
        border-left: 4px solid var(--yellow);
      }
      .match-date-box {
        background: var(--yellow);
        color: var(--black);
        border-radius: 6px;
        padding: 10px 14px;
        text-align: center;
        min-width: 56px;
      }
      .match-date-box .day {
        font-family: "Bebas Neue", sans-serif;
        font-size: 1.8rem;
        line-height: 1;
      }
      .match-date-box .month {
        font-size: 0.65rem;
        font-weight: 800;
        letter-spacing: 1px;
        text-transform: uppercase;
      }
      .match-info {
        flex: 1;
      }
      .match-info h4 {
        font-size: 0.95rem;
        font-weight: 700;
        margin-bottom: 4px;
      }
      .match-info p {
        font-size: 0.8rem;
        color: #888;
      }
      .match-type {
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: var(--yellow);
        padding: 4px 10px;
        border: 1px solid var(--yellow);
        border-radius: 3px;
      }
      .infos-box {
        background: var(--mid);
        border-radius: 12px;
        padding: 40px;
        border: 1px solid #333;
      }
      .infos-box h3 {
        font-family: "Bebas Neue", sans-serif;
        font-size: 1.8rem;
        margin-bottom: 28px;
        color: var(--yellow);
      }
      .info-row {
        display: flex;
        gap: 16px;
        align-items: flex-start;
        margin-bottom: 24px;
      }
      .info-row .icon {
        font-size: 1.4rem;
        flex-shrink: 0;
        margin-top: 2px;
      }
      .info-row h4 {
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        margin-bottom: 4px;
        color: #aaa;
      }
      .info-row p {
        font-size: 0.95rem;
        color: var(--white);
        line-height: 1.5;
      }

      /* ── HISTOIRE ── */
      #histoire {
        background: var(--yellow);
        color: var(--black);
      }
      #histoire .section-eyebrow {
        color: rgba(0, 0, 0, 0.5);
      }
      #histoire .section-title {
        color: var(--black);
      }
      #histoire .section-lead {
        color: rgba(0, 0, 0, 0.7);
      }
      .histoire-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        margin-top: 56px;
        align-items: center;
      }
      .timeline {
        position: relative;
      }
      .timeline-item {
        display: flex;
        gap: 24px;
        margin-bottom: 36px;
      }
      .timeline-year {
        font-family: "Bebas Neue", sans-serif;
        font-size: 2rem;
        color: var(--black);
        min-width: 80px;
        text-align: right;
        line-height: 1;
      }
      .timeline-dot {
        width: 14px;
        height: 14px;
        background: var(--black);
        border-radius: 50%;
        flex-shrink: 0;
        margin-top: 5px;
        position: relative;
      }
      .timeline-dot::after {
        content: "";
        position: absolute;
        left: 50%;
        top: 14px;
        transform: translateX(-50%);
        width: 2px;
        height: calc(100% + 22px);
        background: rgba(0, 0, 0, 0.2);
      }
      .timeline-item:last-child .timeline-dot::after {
        display: none;
      }
      .timeline-text h4 {
        font-size: 0.95rem;
        font-weight: 700;
        margin-bottom: 4px;
      }
      .timeline-text p {
        font-size: 0.85rem;
        color: rgba(0, 0, 0, 0.65);
        line-height: 1.5;
      }
      .histoire-logo-wrap {
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .histoire-logo-wrap img {
        width: 340px;
        height: auto;
        border-radius: 16px;
        box-shadow: 0 20px 80px rgba(0, 0, 0, 0.25);
      }

      /* ── BUREAU ── */
      #bureau {
        background: var(--black);
      }
      .bureau-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 24px;
        margin-top: 56px;
      }
      .bureau-card {
        background: var(--mid);
        border-radius: 12px;
        padding: 32px 24px;
        text-align: center;
        border: 1px solid #333;
        transition:
          border-color 0.2s,
          transform 0.2s;
      }
      .bureau-card:hover {
        border-color: var(--yellow);
        transform: translateY(-4px);
      }
      .bureau-avatar {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: var(--yellow);
        color: var(--black);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 1.5rem;
        margin: 0 auto 18px;
        border: 3px solid #444;
      }
      .bureau-card.president .bureau-avatar {
        border-color: var(--yellow);
        box-shadow: 0 0 20px rgba(245, 200, 0, 0.3);
      }
      .bureau-role {
        font-size: 0.68rem;
        font-weight: 800;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--yellow);
        margin-bottom: 8px;
        display: block;
      }
      .bureau-card h3 {
        font-size: 1rem;
        font-weight: 700;
        margin-bottom: 4px;
      }
      .bureau-card p {
        font-size: 0.82rem;
        color: #888;
      }
      .bureau-contact {
        display: flex;
        gap: 8px;
        justify-content: center;
        margin-top: 16px;
      }
      .bureau-contact a {
        background: #333;
        color: #ccc;
        width: 34px;
        height: 34px;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.85rem;
        text-decoration: none;
        border: 1px solid #444;
        transition: all 0.2s;
      }
      .bureau-contact a:hover {
        border-color: var(--yellow);
        color: var(--yellow);
      }

      /* ── ADHÉSION ── */
      #adhesion {
        background: var(--dark);
      }
      .adhesion-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 24px;
        margin-top: 56px;
      }
      .tarif-card {
        border: 2px solid #333;
        border-radius: 12px;
        padding: 36px 28px;
        text-align: center;
        transition:
          border-color 0.2s,
          transform 0.2s;
        position: relative;
      }
      .tarif-card.featured {
        border-color: var(--yellow);
        background: rgba(245, 200, 0, 0.05);
      }
      .tarif-badge {
        position: absolute;
        top: -14px;
        left: 50%;
        transform: translateX(-50%);
        background: var(--yellow);
        color: var(--black);
        font-size: 0.68rem;
        font-weight: 800;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        padding: 5px 16px;
        border-radius: 20px;
        white-space: nowrap;
      }
      .tarif-card:hover {
        transform: translateY(-4px);
      }
      .tarif-cat {
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--yellow);
        margin-bottom: 12px;
      }
      .tarif-price {
        font-family: "Bebas Neue", sans-serif;
        font-size: 3.5rem;
        line-height: 1;
        margin-bottom: 4px;
      }
      .tarif-period {
        font-size: 0.8rem;
        color: #888;
        margin-bottom: 24px;
      }
      .tarif-features {
        list-style: none;
        text-align: left;
        margin-bottom: 28px;
      }
      .tarif-features li {
        font-size: 0.88rem;
        color: #bbb;
        padding: 6px 0;
        border-bottom: 1px solid #2a2a2a;
        display: flex;
        gap: 10px;
        align-items: center;
      }
      .tarif-features li::before {
        content: "✓";
        color: var(--yellow);
        font-weight: 700;
      }

      /* ── CONTACT ── */
      #contact {
        background: var(--black);
      }
      .contact-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        margin-top: 56px;
      }
      .contact-form {
        display: flex;
        flex-direction: column;
        gap: 16px;
      }
      .form-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .form-group label {
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #888;
      }
      .form-group input,
      .form-group textarea,
      .form-group select {
        background: var(--mid);
        border: 1px solid #444;
        border-radius: 6px;
        padding: 14px 16px;
        color: var(--white);
        font-family: "Inter", sans-serif;
        font-size: 0.95rem;
        transition: border-color 0.2s;
        outline: none;
      }
      .form-group input:focus,
      .form-group textarea:focus,
      .form-group select:focus {
        border-color: var(--yellow);
      }
      .form-group textarea {
        resize: vertical;
        min-height: 120px;
      }
      .form-group select option {
        background: var(--mid);
      }
      .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
      }
      .btn-submit {
        background: var(--yellow);
        color: var(--black);
        border: none;
        padding: 16px;
        border-radius: 6px;
        font-weight: 800;
        font-size: 0.9rem;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        cursor: pointer;
        transition:
          background 0.2s,
          transform 0.15s;
        margin-top: 8px;
      }
      .btn-submit:hover {
        background: var(--yellow-dark);
        transform: translateY(-2px);
      }
      .contact-infos {
        display: flex;
        flex-direction: column;
        gap: 32px;
      }
      .contact-info-block h3 {
        font-family: "Bebas Neue", sans-serif;
        font-size: 1.6rem;
        color: var(--yellow);
        margin-bottom: 16px;
      }
      .contact-info-item {
        display: flex;
        gap: 14px;
        align-items: flex-start;
        margin-bottom: 16px;
      }
      .contact-info-item .icon {
        font-size: 1.2rem;
        flex-shrink: 0;
      }
      .contact-info-item p {
        font-size: 0.95rem;
        color: #ccc;
        line-height: 1.5;
      }
      .social-links {
        display: flex;
        gap: 16px;
        margin-top: 8px;
      }
      .social-link {
        background: var(--mid);
        color: var(--white);
        width: 46px;
        height: 46px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        text-decoration: none;
        border: 1px solid #444;
        transition: all 0.2s;
      }
      .social-link:hover {
        border-color: var(--yellow);
      }

      /* ── FOOTER ── */
      footer {
        background: var(--black);
        border-top: 2px solid var(--yellow);
        padding: 48px 40px 32px;
      }
      .footer-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 40px;
        margin-bottom: 40px;
      }
      .footer-brand {
        display: flex;
        align-items: center;
        gap: 16px;
      }
      .footer-brand img {
        height: 80px;
        width: auto;
        border-radius: 8px;
        border: 1px solid var(--yellow);
      }
      .footer-brand-text h2 {
        font-family: "Bebas Neue", sans-serif;
        font-size: 1.6rem;
        color: var(--yellow);
        letter-spacing: 2px;
      }
      .footer-brand-text p {
        font-size: 0.82rem;
        color: #666;
        margin-top: 2px;
      }
      .footer-links h4 {
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: #888;
        margin-bottom: 16px;
      }
      .footer-links ul {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 10px;
      }
      .footer-links a {
        color: #ccc;
        text-decoration: none;
        font-size: 0.9rem;
        transition: color 0.2s;
        cursor: pointer;
      }
      .footer-links a:hover {
        color: var(--yellow);
      }
      .footer-bottom {
        border-top: 1px solid #222;
        padding-top: 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 12px;
      }
      .footer-bottom p {
        font-size: 0.8rem;
        color: #555;
      }
      .footer-bottom span {
        color: var(--yellow);
      }

      /* ── MODAL OVERLAY ── */
      .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.85);
        z-index: 500;
        align-items: center;
        justify-content: center;
        padding: 20px;
      }
      .modal-overlay.open {
        display: flex;
      }
      .modal {
        background: var(--dark);
        border-radius: 16px;
        border: 1px solid #333;
        width: 100%;
        max-width: 480px;
        overflow: hidden;
        max-height: calc(100vh - 32px);
        display: flex;
        flex-direction: column;
      }
      .modal-body {
        overflow-y: auto;
      }
      .modal-overlay {
        overflow-y: auto;
      }
      .modal-header {
        background: var(--mid);
        padding: 24px 28px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid #333;
      }
      .modal-header h2 {
        font-family: "Bebas Neue", sans-serif;
        font-size: 1.6rem;
        color: var(--yellow);
        letter-spacing: 1px;
      }
      .modal-close {
        background: none;
        border: none;
        color: #888;
        font-size: 1.5rem;
        cursor: pointer;
        transition: color 0.2s;
        line-height: 1;
      }
      .modal-close:hover {
        color: var(--white);
      }
      .modal-body {
        padding: 28px;
      }
      .modal-tabs {
        display: flex;
        gap: 0;
        margin-bottom: 24px;
        border: 1px solid #444;
        border-radius: 8px;
        overflow: hidden;
      }
      .modal-tab {
        flex: 1;
        padding: 10px;
        background: none;
        border: none;
        color: #888;
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.2s;
      }
      .modal-tab.active {
        background: var(--yellow);
        color: var(--black);
      }
      .modal-form {
        display: flex;
        flex-direction: column;
        gap: 16px;
      }
      .modal-form label {
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #888;
        display: block;
        margin-bottom: 6px;
      }
      .modal-form input,
      .modal-form select {
        width: 100%;
        background: var(--mid);
        border: 1px solid #444;
        border-radius: 8px;
        padding: 13px 16px;
        color: var(--white);
        font-family: "Inter", sans-serif;
        font-size: 0.95rem;
        outline: none;
        transition: border-color 0.2s;
      }
      .modal-form input:focus,
      .modal-form select:focus {
        border-color: var(--yellow);
      }
      .modal-form select option {
        background: var(--mid);
      }
      .modal-submit {
        width: 100%;
        background: var(--yellow);
        color: var(--black);
        border: none;
        padding: 15px;
        border-radius: 8px;
        font-weight: 800;
        font-size: 0.9rem;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        cursor: pointer;
        margin-top: 8px;
        transition: background 0.2s;
      }
      .modal-submit:hover {
        background: var(--yellow-dark);
      }
      .modal-footer {
        text-align: center;
        margin-top: 16px;
        font-size: 0.85rem;
        color: #888;
      }
      .modal-footer a {
        color: var(--yellow);
        cursor: pointer;
        text-decoration: none;
      }
      .tab-panel {
        display: none;
      }
      .tab-panel.active {
        display: flex;
        flex-direction: column;
        gap: 16px;
      }

      /* ── ESPACE MEMBRE ── */
      #page-membre {
        min-height: 100vh;
        padding-top: 72px;
        background: var(--black);
      }
      .membre-layout {
        display: grid;
        grid-template-columns: 280px 1fr;
        min-height: calc(100vh - 72px);
      }
      .membre-sidebar {
        background: var(--dark);
        border-right: 1px solid #333;
        padding: 32px 0;
      }
      .membre-profile-mini {
        padding: 24px 28px 28px;
        border-bottom: 1px solid #333;
        text-align: center;
      }
      .membre-avatar-lg {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: var(--yellow);
        color: var(--black);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        font-size: 1.8rem;
        margin: 0 auto 14px;
        border: 3px solid #444;
      }
      .membre-profile-mini h3 {
        font-size: 1rem;
        font-weight: 700;
        margin-bottom: 4px;
      }
      .membre-profile-mini p {
        font-size: 0.82rem;
        color: #888;
      }
      .membre-badge {
        display: inline-block;
        margin-top: 10px;
        background: rgba(245, 200, 0, 0.15);
        color: var(--yellow);
        font-size: 0.68rem;
        font-weight: 800;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        padding: 4px 12px;
        border-radius: 20px;
        border: 1px solid rgba(245, 200, 0, 0.3);
      }
      .sidebar-nav {
        padding: 16px 0;
      }
      .sidebar-nav-item {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px 28px;
        color: #888;
        font-size: 0.88rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        border-left: 3px solid transparent;
        text-decoration: none;
      }
      .sidebar-nav-item:hover {
        color: var(--white);
        background: rgba(255, 255, 255, 0.04);
      }
      .sidebar-nav-item.active {
        color: var(--yellow);
        border-left-color: var(--yellow);
        background: rgba(245, 200, 0, 0.06);
      }
      .sidebar-nav-item .icon {
        font-size: 1.1rem;
        width: 22px;
        text-align: center;
      }
      .sidebar-section-label {
        padding: 20px 28px 8px;
        font-size: 0.65rem;
        font-weight: 800;
        letter-spacing: 2.5px;
        text-transform: uppercase;
        color: #555;
      }
      .membre-main {
        padding: 40px;
        overflow-y: auto;
      }
      .membre-panel {
        display: none;
      }
      .membre-panel.active {
        display: block;
      }
      .panel-title {
        font-family: "Bebas Neue", sans-serif;
        font-size: 2.2rem;
        color: var(--yellow);
        letter-spacing: 1px;
        margin-bottom: 8px;
      }
      .panel-subtitle {
        font-size: 0.9rem;
        color: #888;
        margin-bottom: 36px;
      }

      /* Fiche joueur */
      .fiche-grid {
        display: grid;
        grid-template-columns: 300px 1fr;
        gap: 32px;
        margin-bottom: 32px;
        align-items: start;
      }
      .fiche-card {
        background: var(--dark);
        border-radius: 12px;
        border: 1px solid #333;
        padding: 32px;
        text-align: center;
      }
      .fiche-avatar {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background: var(--yellow);
        color: var(--black);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        font-size: 2rem;
        margin: 0 auto 20px;
        border: 4px solid #333;
      }
      .fiche-name {
        font-family: "Bebas Neue", sans-serif;
        font-size: 1.8rem;
        letter-spacing: 1px;
        margin-bottom: 4px;
      }
      .fiche-number {
        font-family: "Bebas Neue", sans-serif;
        font-size: 4rem;
        color: var(--yellow);
        line-height: 1;
        margin-bottom: 12px;
      }
      .fiche-pos {
        display: inline-block;
        background: var(--yellow);
        color: var(--black);
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 2px;
        text-transform: uppercase;
        padding: 5px 14px;
        border-radius: 20px;
        margin-bottom: 20px;
      }
      .fiche-stats-mini {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-top: 20px;
      }
      .fiche-stat-mini {
        background: var(--mid);
        border-radius: 8px;
        padding: 12px;
        text-align: center;
      }
      .fiche-stat-mini .num {
        font-family: "Bebas Neue", sans-serif;
        font-size: 1.6rem;
        color: var(--yellow);
      }
      .fiche-stat-mini .lbl {
        font-size: 0.68rem;
        color: #888;
        text-transform: uppercase;
        letter-spacing: 1px;
      }
      .fiche-infos {
        background: var(--dark);
        border-radius: 12px;
        border: 1px solid #333;
        padding: 32px;
      }
      .fiche-section-title {
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--yellow);
        margin-bottom: 20px;
        padding-bottom: 10px;
        border-bottom: 1px solid #333;
      }
      .fiche-field {
        display: grid;
        grid-template-columns: 160px 1fr;
        gap: 12px;
        align-items: center;
        padding: 10px 0;
        border-bottom: 1px solid #222;
      }
      .fiche-field:last-child {
        border-bottom: none;
      }
      .fiche-field label {
        font-size: 0.78rem;
        color: #888;
        font-weight: 600;
      }
      .fiche-field span {
        font-size: 0.9rem;
        color: var(--white);
      }
      .fiche-field input,
      .fiche-field select {
        background: var(--mid);
        border: 1px solid #555;
        border-radius: 6px;
        padding: 8px 12px;
        color: var(--white);
        font-family: "Inter", sans-serif;
        font-size: 0.9rem;
        outline: none;
        width: 100%;
      }
      .fiche-field input:focus,
      .fiche-field select:focus {
        border-color: var(--yellow);
      }
      .edit-btn {
        background: rgba(245, 200, 0, 0.1);
        color: var(--yellow);
        border: 1px solid rgba(245, 200, 0, 0.3);
        padding: 8px 18px;
        border-radius: 6px;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.2s;
      }
      .edit-btn:hover {
        background: var(--yellow);
        color: var(--black);
      }
      .save-btn {
        background: var(--yellow);
        color: var(--black);
        border: none;
        padding: 10px 24px;
        border-radius: 6px;
        font-size: 0.82rem;
        font-weight: 800;
        letter-spacing: 1px;
        text-transform: uppercase;
        cursor: pointer;
        transition: background 0.2s;
      }
      .save-btn:hover {
        background: var(--yellow-dark);
      }

      /* Enfants liés */
      .children-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 20px;
        margin-top: 24px;
      }
      .child-card {
        background: var(--dark);
        border-radius: 12px;
        border: 1px solid #333;
        padding: 24px;
        transition: border-color 0.2s;
      }
      .child-card:hover {
        border-color: var(--yellow);
      }
      .child-header {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 20px;
      }
      .child-avatar {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: #3b82f6;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 1rem;
        flex-shrink: 0;
      }
      .child-avatar {
        overflow: hidden;
      }
      .child-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      .child-card h3 {
        font-size: 0.95rem;
        font-weight: 700;
        margin-bottom: 3px;
      }
      .child-card .child-meta {
        font-size: 0.78rem;
        color: #888;
      }
      .child-info-row {
        display: flex;
        justify-content: space-between;
        font-size: 0.82rem;
        padding: 6px 0;
        border-bottom: 1px solid #222;
      }
      .child-info-row:last-child {
        border-bottom: none;
      }
      .child-info-row span:first-child {
        color: #888;
      }
      .add-child-btn {
        border: 2px dashed #444;
        border-radius: 12px;
        padding: 32px;
        text-align: center;
        cursor: pointer;
        transition: all 0.2s;
        color: #888;
        background: none;
        width: 100%;
      }
      .add-child-btn:hover {
        border-color: var(--yellow);
        color: var(--yellow);
      }
      .add-child-btn .plus {
        font-size: 2rem;
        display: block;
        margin-bottom: 8px;
      }
      .add-child-btn span {
        font-size: 0.85rem;
        font-weight: 600;
      }

      /* Documents */
      .docs-toolbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 28px;
        flex-wrap: wrap;
        gap: 16px;
      }
      .docs-search {
        background: var(--mid);
        border: 1px solid #444;
        border-radius: 8px;
        padding: 11px 16px;
        color: var(--white);
        font-family: "Inter", sans-serif;
        font-size: 0.9rem;
        outline: none;
        width: 280px;
        transition: border-color 0.2s;
      }
      .docs-search:focus {
        border-color: var(--yellow);
      }
      .docs-folder-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 16px;
        margin-bottom: 36px;
      }
      .folder-card {
        background: var(--dark);
        border: 1px solid #333;
        border-radius: 10px;
        padding: 20px;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        gap: 14px;
      }
      .folder-card:hover {
        border-color: var(--yellow);
        background: rgba(245, 200, 0, 0.04);
      }
      .folder-icon {
        font-size: 2rem;
        flex-shrink: 0;
      }
      .folder-card h4 {
        font-size: 0.88rem;
        font-weight: 700;
        margin-bottom: 3px;
      }
      .folder-card p {
        font-size: 0.75rem;
        color: #888;
      }
      .docs-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
      }
      .doc-row {
        background: var(--dark);
        border: 1px solid #333;
        border-radius: 8px;
        padding: 16px 20px;
        display: flex;
        align-items: center;
        gap: 16px;
        transition: border-color 0.2s;
      }
      .doc-row:hover {
        border-color: #555;
      }
      .doc-type-badge {
        font-size: 0.62rem;
        font-weight: 800;
        letter-spacing: 1px;
        text-transform: uppercase;
        padding: 3px 8px;
        border-radius: 4px;
        flex-shrink: 0;
      }
      .doc-type-badge.pdf {
        background: rgba(239, 68, 68, 0.15);
        color: #f87171;
      }
      .doc-type-badge.word {
        background: rgba(59, 130, 246, 0.15);
        color: #60a5fa;
      }
      .doc-type-badge.excel {
        background: rgba(34, 197, 94, 0.15);
        color: #4ade80;
      }
      .doc-type-badge.img {
        background: rgba(168, 85, 247, 0.15);
        color: #c084fc;
      }
      .doc-info {
        flex: 1;
        min-width: 0;
      }
      .doc-info h4 {
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 3px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .doc-info p {
        font-size: 0.75rem;
        color: #888;
      }
      .doc-size {
        font-size: 0.75rem;
        color: #666;
        flex-shrink: 0;
      }
      .doc-actions {
        display: flex;
        gap: 8px;
        flex-shrink: 0;
      }
      .doc-btn {
        background: #333;
        border: 1px solid #444;
        border-radius: 6px;
        color: #ccc;
        padding: 6px 12px;
        font-size: 0.75rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
      }
      .doc-btn:hover {
        border-color: var(--yellow);
        color: var(--yellow);
      }
      .doc-btn.danger:hover {
        border-color: var(--red);
        color: var(--red);
      }
      .upload-zone {
        border: 2px dashed #444;
        border-radius: 12px;
        padding: 40px;
        text-align: center;
        cursor: pointer;
        transition: all 0.2s;
        margin-bottom: 24px;
      }
      .upload-zone:hover {
        border-color: var(--yellow);
        background: rgba(245, 200, 0, 0.03);
      }
      .upload-zone p {
        color: #888;
        font-size: 0.9rem;
      }
      .upload-zone .upload-icon {
        font-size: 2.5rem;
        display: block;
        margin-bottom: 12px;
      }
      .upload-zone strong {
        color: var(--yellow);
      }

      /* Notifications / messages */
      .notif-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
      }
      .notif-item {
        background: var(--dark);
        border-radius: 10px;
        border: 1px solid #333;
        padding: 18px 20px;
        display: flex;
        gap: 16px;
        align-items: flex-start;
      }
      .notif-item.unread {
        border-left: 3px solid var(--yellow);
      }
      .notif-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: var(--yellow);
        flex-shrink: 0;
        margin-top: 5px;
      }
      .notif-dot.read {
        background: #444;
      }
      .notif-content h4 {
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 4px;
      }
      .notif-content p {
        font-size: 0.82rem;
        color: #888;
        line-height: 1.5;
      }
      .notif-time {
        font-size: 0.72rem;
        color: #666;
        margin-top: 6px;
        display: block;
      }

      /* Stats panel */
      .stats-grid-panel {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        gap: 16px;
        margin-bottom: 32px;
      }
      .stat-card-panel {
        background: var(--dark);
        border: 1px solid #333;
        border-radius: 10px;
        padding: 20px;
      }
      .stat-card-panel .val {
        font-family: "Bebas Neue", sans-serif;
        font-size: 2.4rem;
        color: var(--yellow);
        line-height: 1;
        margin-bottom: 4px;
      }
      .stat-card-panel .lbl {
        font-size: 0.72rem;
        color: #888;
        text-transform: uppercase;
        letter-spacing: 1.5px;
      }
      .progress-row {
        margin-bottom: 16px;
      }
      .progress-row label {
        font-size: 0.8rem;
        color: #aaa;
        display: flex;
        justify-content: space-between;
        margin-bottom: 6px;
      }
      .progress-bar {
        height: 8px;
        background: #333;
        border-radius: 4px;
        overflow: hidden;
      }
      .progress-fill {
        height: 100%;
        background: var(--yellow);
        border-radius: 4px;
        transition: width 1s ease;
      }

      /* Admin */
      .admin-tabs {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 28px;
      }
      .admin-tab {
        background: var(--mid);
        border: 1px solid #444;
        border-radius: 20px;
        color: #aaa;
        padding: 8px 16px;
        font-size: 0.8rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.2s;
        font-family: "Inter", sans-serif;
      }
      .admin-tab:hover {
        border-color: var(--yellow);
        color: var(--yellow);
      }
      .admin-tab.active {
        background: var(--yellow);
        border-color: var(--yellow);
        color: var(--black);
      }
      .admin-form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
      }
      .admin-form-grid .full {
        grid-column: 1 / -1;
      }
      .admin-form-grid label {
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #888;
        display: block;
        margin-bottom: 6px;
      }
      .admin-form-grid input,
      .admin-form-grid textarea {
        width: 100%;
        background: var(--mid);
        border: 1px solid #444;
        border-radius: 6px;
        padding: 11px 14px;
        color: var(--white);
        font-family: "Inter", sans-serif;
        font-size: 0.9rem;
        outline: none;
      }
      .admin-form-grid input:focus,
      .admin-form-grid textarea:focus {
        border-color: var(--yellow);
      }
      .admin-form-grid textarea {
        min-height: 90px;
        resize: vertical;
      }
      .admin-form-grid input[type="checkbox"] {
        width: 20px;
        height: 20px;
        accent-color: var(--yellow);
      }
      .admin-hint {
        font-size: 0.75rem;
        color: #777;
        margin-top: 4px;
      }
      @media (max-width: 700px) {
        .admin-form-grid {
          grid-template-columns: 1fr;
        }
      }

      /* Bannière annonce */
      .annonce-banner {
        display: none;
        position: fixed;
        top: 72px;
        left: 0;
        right: 0;
        z-index: 150;
        background: var(--yellow);
        color: var(--black);
        padding: 14px 20px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
      }
      .annonce-banner.show {
        display: flex;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
      }
      .annonce-banner .ab-text {
        flex: 1;
        min-width: 200px;
      }
      .annonce-banner h4 {
        font-size: 0.95rem;
        font-weight: 800;
        margin-bottom: 2px;
      }
      .annonce-banner p {
        font-size: 0.85rem;
        line-height: 1.4;
      }
      .annonce-banner button {
        background: var(--black);
        color: var(--yellow);
        border: none;
        border-radius: 6px;
        padding: 10px 18px;
        font-weight: 800;
        font-size: 0.8rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        cursor: pointer;
        flex-shrink: 0;
      }

      /* Toast */
      .toast {
        position: fixed;
        bottom: 30px;
        right: 30px;
        background: var(--green);
        color: white;
        padding: 14px 22px;
        border-radius: 8px;
        font-size: 0.88rem;
        font-weight: 600;
        z-index: 9999;
        transform: translateY(80px);
        opacity: 0;
        transition: all 0.3s;
        pointer-events: none;
      }
      .toast.show {
        transform: translateY(0);
        opacity: 1;
      }
      .toast.error {
        background: var(--red);
      }

      /* Responsive */
      @media (max-width: 1000px) {
        .membre-layout {
          grid-template-columns: 1fr;
        }
        .membre-sidebar {
          display: flex;
          overflow-x: auto;
          padding: 0;
          border-right: none;
          border-bottom: 1px solid #333;
        }
        .membre-profile-mini {
          display: none;
        }
        .sidebar-nav {
          display: flex;
          flex-direction: row;
          padding: 0;
        }
        .sidebar-section-label {
          display: none;
        }
        .sidebar-nav-item {
          padding: 14px 16px;
          border-left: none;
          border-bottom: 3px solid transparent;
          white-space: nowrap;
        }
        .sidebar-nav-item.active {
          border-bottom-color: var(--yellow);
          border-left-color: transparent;
        }
        .fiche-grid {
          grid-template-columns: 1fr;
        }
      }
      .nav-burger {
        display: none;
        background: none;
        border: 2px solid var(--yellow);
        border-radius: 6px;
        color: var(--yellow);
        font-size: 1.3rem;
        width: 44px;
        height: 44px;
        cursor: pointer;
        line-height: 1;
      }
      .mobile-menu {
        display: none;
        position: fixed;
        top: 72px;
        left: 0;
        right: 0;
        background: rgba(13, 13, 13, 0.98);
        backdrop-filter: blur(12px);
        border-bottom: 2px solid var(--yellow);
        z-index: 199;
        padding: 12px 0;
      }
      .mobile-menu.open {
        display: block;
      }
      .mobile-menu a {
        display: block;
        padding: 15px 28px;
        color: var(--white);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        cursor: pointer;
        border-bottom: 1px solid #222;
      }
      .mobile-menu a:last-child {
        border-bottom: none;
      }
      .mobile-menu a:hover {
        color: var(--yellow);
        background: rgba(245, 200, 0, 0.06);
      }
      @media (max-width: 900px) {
        nav {
          padding: 0 20px;
        }
        .nav-links {
          display: none !important;
        }
        .nav-burger {
          display: block;
        }
        #hero {
          padding: 100px 24px 60px;
        }
        .hero-logo-float {
          display: none;
        }
        .hero-stripe {
          width: 0;
        }
        section {
          padding: 70px 24px;
        }
        .agenda-layout,
        .histoire-layout,
        .contact-layout {
          grid-template-columns: 1fr;
          gap: 40px;
        }
        .histoire-logo-wrap img {
          width: 220px;
          height: auto;
        }
        .footer-top {
          flex-direction: column;
        }
        .membre-main {
          padding: 24px;
        }
      }
    </style>
  </head>
  <body>
