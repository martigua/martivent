          .order("created_at", { ascending: false })
          .limit(1);
        if (!data || !data.length) return;
        const n = data[0];
        const vue = currentProfile.derniere_notif_vue;
        if (!vue || new Date(n.created_at) > new Date(vue)) {
          derniereAnnonceId = n.created_at;
          document.getElementById("annonce-banner-titre").textContent = n.titre;
          document.getElementById("annonce-banner-texte").textContent =
            (n.texte || "").slice(0, 180) +
            ((n.texte || "").length > 180 ? "…" : "");
          document.getElementById("annonce-banner").classList.add("show");
        }
      }

      async function dismissAnnonce() {
        document.getElementById("annonce-banner").classList.remove("show");
        if (sb && currentUser && derniereAnnonceId) {
          await sb
            .from("profiles")
            .update({ derniere_notif_vue: derniereAnnonceId })
            .eq("id", currentUser.id);
          currentProfile.derniere_notif_vue = derniereAnnonceId;
        }
        showMemberPanel("notifications");
      }

      // ── MESSAGES DE CONTACT ──
      async function sendContactMessage() {
        const msg = {
          prenom: document.getElementById("contact-prenom").value.trim(),
          nom: document.getElementById("contact-nom").value.trim(),
          email: document.getElementById("contact-email").value.trim(),
          objet: document.getElementById("contact-objet").value,
          message: document.getElementById("contact-message").value.trim(),
        };
        if (!msg.message) {
          showToast("Écrivez un message avant d'envoyer.", "error");
          return;
        }
        if (!msg.email) {
          showToast(
            "Indiquez votre email pour que le club puisse vous répondre.",
            "error",
          );
          return;
        }
        if (!sb) {
          showToast("Message envoyé ! (mode démo)");
          return;
        }
        const { error } = await sb.from("messages").insert(msg);
        if (error) {
          showToast("Erreur : " + error.message, "error");
          return;
        }
        [
          "contact-prenom",
          "contact-nom",
          "contact-email",
          "contact-message",
        ].forEach((id) => (document.getElementById(id).value = ""));
        showToast("Message envoyé ! Le club vous répondra rapidement. 📬");
      }

      let messagesCache = [];
      async function loadMessages() {
        if (!sb) return;
        const { data, error } = await sb
          .from("messages")
          .select("*")
          .order("created_at", { ascending: false });
        if (error) {
          showToast("Erreur : " + error.message, "error");
          return;
        }
        messagesCache = data || [];
        updateMessagesBadge(messagesCache.filter((m) => !m.lu).length);
        // Filtre objets : construit à partir des messages reçus
        const filtre = document.getElementById("messages-filtre");
        const cur = filtre.value;
        const objets = [
          ...new Set(messagesCache.map((m) => m.objet).filter(Boolean)),
        ];
        filtre.innerHTML =
          '<option value="">Tous les objets</option>' +
          objets
            .map(
              (o) =>
                `<option${o === cur ? " selected" : ""}>${esc(o)}</option>`,
            )
            .join("");
        const statut = document.getElementById("messages-statut").value;
        const visibles = messagesCache.filter(
          (m) =>
            (!filtre.value || m.objet === filtre.value) &&
            (!statut || (statut === "lu" ? m.lu : !m.lu)),
        );
        document.getElementById("messages-list").innerHTML =
          visibles
            .map((m) => {
              const d = new Date(m.created_at).toLocaleString("fr-FR", {
                day: "numeric",
                month: "long",
                hour: "2-digit",
                minute: "2-digit",
              });
              return `<div class="notif-item${m.lu ? "" : " unread"}">
      <div class="notif-dot${m.lu ? " read" : ""}"></div>
      <div class="notif-content" style="flex:1">
        <h4>${esc(m.objet || "Message")} — ${esc((m.prenom || "") + " " + (m.nom || ""))}</h4>
        <p>${esc(m.message)}</p>
        <span class="notif-time">${d} · <a href="mailto:${esc(m.email)}" style="color:var(--yellow)">${esc(m.email || "")}</a>${m.lu && m.traite_par ? ` · <span style="color:var(--green)">✓ Traité par ${esc(m.traite_par)}${m.traite_le ? " le " + new Date(m.traite_le).toLocaleDateString("fr-FR") : ""}</span>` : ""}</span>
        <div style="display:flex;gap:8px;margin-top:10px">
          ${m.lu ? "" : `<button class="doc-btn" onclick="markMessageRead('${m.id}')">✓ Traité</button>`}
          <button class="doc-btn danger" onclick="deleteMessage('${m.id}')">🗑️ Supprimer</button>
        </div>
      </div></div>`;
            })
            .join("") ||
          '<p style="color:#888">Aucun message ne correspond à ce filtre.</p>';
      }

      function updateMessagesBadge(n) {
        const b = document.getElementById("messages-badge");
        if (!b) return;
        b.textContent = n;
        b.style.display = n > 0 ? "inline-block" : "none";
      }

      async function refreshMessagesBadge() {
        if (!sb || !currentProfile || !currentProfile.is_admin) return;
        const { count } = await sb
          .from("messages")
          .select("*", { count: "exact", head: true })
          .eq("lu", false);
        updateMessagesBadge(count || 0);
      }

      function exportMessages() {
        if (!messagesCache.length) {
          showToast("Aucun message à exporter.", "error");
          return;
        }
        const cols = [
          "created_at",
          "prenom",
          "nom",
          "email",
          "objet",
          "message",
          "lu",
          "traite_par",
          "traite_le",
        ];
        const head = [
          "Date",
          "Prénom",
          "Nom",
          "Email",
          "Objet",
          "Message",
          "Traité",
          "Traité par",
          "Traité le",
        ];
        const csvCell = (v) =>
          '"' +
          String(v ?? "")
            .replace(/"/g, '""')
            .replace(/\r?\n/g, " ") +
          '"';
        const lines = [head.join(";")].concat(
          messagesCache.map((m) =>
            cols
              .map((c) => csvCell(c === "lu" ? (m.lu ? "Oui" : "Non") : m[c]))
              .join(";"),
          ),
        );
        const blob = new Blob(["\ufeff" + lines.join("\n")], {
          type: "text/csv;charset=utf-8",
        });
        const a = document.createElement("a");
        a.href = URL.createObjectURL(blob);
        a.download =
          "messages-martigua-" + new Date().toISOString().slice(0, 10) + ".csv";
        a.click();
        showToast("Export téléchargé ! Ouvrez-le avec Excel. 📊");
      }

      async function markMessageRead(id) {
        const qui =
          ((currentProfile || {}).prenom || "") +
          " " +
          ((currentProfile || {}).nom || "");
        await sb
          .from("messages")
          .update({
            lu: true,
            traite_par: qui.trim(),
            traite_le: new Date().toISOString(),
          })
          .eq("id", id);
        loadMessages();
        showToast("Message marqué comme traité ✓");
      }

      async function deleteMessage(id) {
        if (!confirm("Supprimer ce message ?")) return;
        await sb.from("messages").delete().eq("id", id);
        loadMessages();
        showToast("Message supprimé.");
      }

      // ── TOGGLE COACH ──
      async function toggleCoach(id, val) {
        if (
          !confirm(
            val
              ? "Donner le rôle coach à ce membre ?"
              : "Retirer le rôle coach ?",
          )
        )
          return;
        const { error } = await sb
          .from("profiles")
          .update({ is_coach: val })
          .eq("id", id);
        if (error) {
          showToast("Erreur : " + error.message, "error");
          return;
        }
        loadMembres();
        showToast(val ? "Membre promu coach 🎯" : "Rôle coach retiré.");
      }

      // ── DISPONIBILITÉS ──
      async function loadDispos() {
        if (!sb || !currentUser) return;
        const today = new Date().toISOString().slice(0, 10);
        const container = document.getElementById("dispos-matchs");
        container.innerHTML = '<p style="color:#888">Chargement…</p>';

        const { data: matchs } = await sb
          .from("matchs")
          .select("*")
          .gte("date_match", today)
          .order("date_match")
          .limit(12);

        if (!matchs || matchs.length === 0) {
          container.innerHTML =
            '<p style="color:#888">Aucun match à venir au calendrier.</p>';
          return;
        }

        const { data: myDispos } = await sb
          .from("dispos")
          .select("*")
          .eq("user_id", currentUser.id);
        const myDisposMap = {};
        (myDispos || []).forEach((d) => (myDisposMap[d.match_id] = d));

        const { data: allDispos } = await sb
          .from("dispos")
          .select("match_id, statut");
        const allCounts = {};
        (allDispos || []).forEach((d) => {
          if (!allCounts[d.match_id])
            allCounts[d.match_id] = { dispo: 0, non_dispo: 0 };
          allCounts[d.match_id][d.statut] =
            (allCounts[d.match_id][d.statut] || 0) + 1;
        });

        container.innerHTML = matchs
          .map((m) => {
            const d = new Date(m.date_match);
            const dateStr = d.toLocaleDateString("fr-FR", {
              weekday: "long",
              day: "numeric",
              month: "long",
            });
            const myDispo = myDisposMap[m.id];
            const isDispo = myDispo && myDispo.statut === "dispo";
            const isNonDispo = myDispo && myDispo.statut === "non_dispo";
            const isSelected = myDispo && myDispo.selectionne;
            const counts = allCounts[m.id] || { dispo: 0, non_dispo: 0 };

            return `<div class="dispo-match-card${isSelected ? " selected-card" : ""}">
      <div style="display:flex;align-items:center;gap:16px;margin-bottom:16px;flex-wrap:wrap">
        <div class="dispo-date-box">
          <div class="day">${String(d.getDate()).padStart(2, "0")}</div>
          <div class="month">${MOIS_FR[d.getMonth()]}</div>
        </div>
        <div style="flex:1;min-width:0">
          <div style="font-size:0.98rem;font-weight:700;margin-bottom:4px">
            ${esc(m.titre)}
            ${isSelected ? '<span style="color:#f97316;font-size:0.82rem;margin-left:8px">🔥 Sélectionné·e</span>' : ""}
          </div>
          <div style="font-size:0.8rem;color:#888">${dateStr}${m.lieu ? " · " + esc(m.lieu) : ""}</div>
        </div>
        <span class="match-type" style="flex-shrink:0">${esc(m.type || "")}</span>
      </div>
      <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
        <button class="dispo-btn${isDispo ? " active-dispo" : ""}" onclick="setDispo('${m.id}','dispo')">
          ✅ Disponible${isDispo ? " ✓" : ""}
        </button>
        <button class="dispo-btn${isNonDispo ? " active-non-dispo" : ""}" onclick="setDispo('${m.id}','non_dispo')">
          ❌ Non disponible${isNonDispo ? " ✓" : ""}
        </button>
        ${!myDispo ? '<span style="font-size:0.78rem;color:#666">⚠️ Pas encore répondu</span>' : ""}
      </div>
      ${
        counts.dispo + counts.non_dispo > 0
          ? `
      <div class="dispo-compteur">
        <span class="dispo-count-badge green">✅ ${counts.dispo} dispo${counts.dispo > 1 ? "s" : ""}</span>
        <span class="dispo-count-badge red">❌ ${counts.non_dispo} non dispo${counts.non_dispo > 1 ? "s" : ""}</span>
      </div>`
          : ""
      }
    </div>`;
          })
          .join("");
      }

      async function setDispo(matchId, statut) {
        if (!sb || !currentUser) return;
        const { error } = await sb
          .from("dispos")
          .upsert(
            {
              user_id: currentUser.id,
              match_id: matchId,
              statut,
              updated_at: new Date().toISOString(),
            },
            { onConflict: "user_id,match_id" },
          );
        if (error) {
          showToast("Erreur : " + error.message, "error");
          return;
        }
        loadDispos();
        showToast(
          statut === "dispo"
            ? "✅ Disponibilité enregistrée !"
            : "❌ Non-disponibilité enregistrée.",
        );
      }

      // ── SÉLECTION COACH ──
      let selectionMatchId = null;

      async function loadSelectionPanel() {
        if (!sb || !currentUser) return;
        const today = new Date().toISOString().slice(0, 10);
        const { data: matchs } = await sb
          .from("matchs")
          .select("*")
          .gte("date_match", today)
          .order("date_match")
          .limit(20);

        const sel = document.getElementById("selection-match-sel");
        sel.innerHTML =
          '<option value="">— Sélectionnez un match —</option>' +
          (matchs || [])
            .map((m) => {
              const d = new Date(m.date_match).toLocaleDateString("fr-FR", {
                day: "numeric",
                month: "short",
              });
              return `<option value="${m.id}"${selectionMatchId === m.id ? " selected" : ""}>${d} · ${esc(m.titre)}</option>`;
            })
            .join("");

        if (selectionMatchId) loadSelectionGroups(selectionMatchId);
        else
          document.getElementById("selection-groups").innerHTML =
            '<p style="color:#888">Sélectionnez un match pour afficher les disponibilités.</p>';
      }

      function onSelectionMatchChange() {
        const sel = document.getElementById("selection-match-sel");
        selectionMatchId = sel.value || null;
        if (selectionMatchId) loadSelectionGroups(selectionMatchId);
        else
          document.getElementById("selection-groups").innerHTML =
            '<p style="color:#888">Sélectionnez un match pour afficher les disponibilités.</p>';
      }

      async function loadSelectionGroups(matchId) {
        if (!sb) return;
        const grp = document.getElementById("selection-groups");
        grp.innerHTML = '<p style="color:#888">Chargement…</p>';

        const [{ data: profiles }, { data: dispos }] = await Promise.all([
          sb
            .from("profiles")
            .select("id,prenom,nom,poste,numero,equipe,equipe_id,photo_url")
            .order("nom"),
          sb.from("dispos").select("*").eq("match_id", matchId),
        ]);

        const disposMap = {};
        (dispos || []).forEach((d) => (disposMap[d.user_id] = d));

        const disponibles = [],
          non_dispos = [],
          sans_reponse = [];
        (profiles || []).forEach((p) => {
          const d = disposMap[p.id];
          if (!d) sans_reponse.push(p);
          else if (d.statut === "dispo") disponibles.push({ ...p, dispo: d });
          else non_dispos.push({ ...p, dispo: d });
        });

        const renderMembre = (p, showFire) => {
          const initials = (
            (p.prenom || "?")[0] + (p.nom || "?")[0]
          ).toUpperCase();
          const av = p.photo_url
            ? `<div class="membre-row-av"><img src="${esc(p.photo_url)}" alt=""></div>`
            : `<div class="membre-row-av">${initials}</div>`;
          const isSelected = p.dispo && p.dispo.selectionne;
          const dispoId = p.dispo ? p.dispo.id : "";
          const fireBtn = showFire
            ? `<button class="fire-btn${isSelected ? " active" : ""}"
           title="${isSelected ? "Retirer de la sélection" : "Sélectionner"}"
           onclick="toggleSelection('${dispoId}','${p.id}','${matchId}',${!!isSelected})">
           ${isSelected ? "🔥" : "⬜"}
         </button>`
            : "";
          return `<div class="doc-row" style="padding:12px 16px;gap:12px">
      ${av}
      <div class="doc-info">
        <h4>${esc((p.prenom || "") + " " + (p.nom || ""))}${isSelected ? ' <span style="color:#f97316;font-size:0.78rem">🔥 Sélectionné·e</span>' : ""}</h4>
        <p>${esc(p.poste || "—")}${p.numero ? " · #" + esc(p.numero) : ""}${p.equipe ? " · " + esc(p.equipe) : ""}</p>
      </div>
      ${fireBtn}
    </div>`;
        };

        const section = (header, cls, list, showFire, emptyMsg) => `
    <div class="selection-group">
      <div class="selection-group-header ${cls}">${header} <span style="opacity:.6">(${list.length})</span></div>
      <div>${
        list.length
          ? list.map((p) => renderMembre(p, showFire)).join("")
          : `<p style="padding:12px 16px;color:#888;font-size:0.85rem">${emptyMsg}</p>`
      }
      </div>
    </div>`;

        grp.innerHTML =
          section(
            "✅ Disponibles",
            "green",
            disponibles,
            true,
            "Aucun·e disponible pour le moment.",
          ) +
          section(
            "⚠️ Sans réponse",
            "orange",
            sans_reponse,
            false,
            "Tout le monde a répondu — bravo !",
          ) +
          section(
            "❌ Non disponibles",
            "red",
            non_dispos,
            false,
            "Aucun·e non disponible.",
          );
      }

      async function toggleSelection(dispoId, userId, matchId, currentVal) {
        if (!sb) return;
        const newVal = !currentVal;
        let error;
        if (!dispoId) {
          ({ error } = await sb.from("dispos").insert({
            user_id: userId,
            match_id: matchId,
            statut: "dispo",
            selectionne: newVal,
            updated_at: new Date().toISOString(),
          }));
        } else {
          ({ error } = await sb
            .from("dispos")
            .update({ selectionne: newVal })
            .eq("id", dispoId));
        }
        if (error) {
          showToast("Erreur : " + error.message, "error");
          return;
        }
        loadSelectionGroups(matchId);
        showToast(
          newVal ? "🔥 Joueur·se sélectionné·e !" : "Sélection retirée.",
        );
      }

      // ── SESSION PERSISTANTE : reconnexion auto ──
      if (sb) {
        sb.auth.getSession().then(({ data }) => {
          if (data.session) {
            currentUser = data.session.user;
            loadProfile();
          }
        });
      }
    </script>
  </body>
</html>
